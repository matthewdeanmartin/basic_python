10 REM ==============================================
20 REM   INTEGRATION TEST: PERSONAL FINANCE SUITE
30 REM   EXERCISES: ARRAYS, LOOPS, LOGIC, GOSUB
40 REM ==============================================
50 PRINT "STARTING AUTOMATED TEST SUITE..."
60 PRINT ""

100 REM --- SECTION 1: COMPOUND INTEREST (FOR/NEXT) ---
110 PRINT "--- TEST 1: SAVINGS CALCULATOR ---"
120 PR = 1000 : REM PRINCIPAL
130 RA = 0.05 : REM RATE 5 PERCENT
140 YE = 10   : REM YEARS
150 PRINT "INITIAL PRINCIPAL: "; PR
160 PRINT "INTEREST RATE:     "; RA
170 FOR I = 1 TO YE
180   IN = PR * RA
190   PR = PR + IN
200   REM TRUNCATE TO 2 DECIMALS USING INT LOGIC
210   PR = INT(PR * 100) / 100
220   PRINT "YEAR "; I; " BALANCE: "; PR
230 NEXT I
240 IF PR > 1600 THEN PRINT "RESULT: PASS (Growth verified)"
250 IF PR <= 1600 THEN PRINT "RESULT: FAIL (Growth too low)"
260 PRINT ""

300 REM --- SECTION 2: CHECKBOOK BALANCER (DIM/ARRAYS) ---
310 PRINT "--- TEST 2: CHECKBOOK (ARRAYS) ---"
320 DIM TR(5) : REM TRANSACTIONS ARRAY
330 REM SIMULATE DATA ENTRY (NO INPUT STMT)
340 TR(0) = 500.00  : REM PAYCHECK
350 TR(1) = -50.25  : REM GROCERIES
360 TR(2) = -100.00 : REM UTILITIES
370 TR(3) = 25.00   : REM REFUND
380 TR(4) = -200.00 : REM RENT
390 BA = 0
400 DE = 0 : REM DEPOSIT COUNT
410 WI = 0 : REM WITHDRAWAL COUNT
420 FOR I = 0 TO 4
430   BA = BA + TR(I)
440   IF TR(I) >= 0 THEN DE = DE + 1
450   IF TR(I) < 0 THEN WI = WI + 1
460 NEXT I
470 PRINT "FINAL BALANCE: "; BA
480 PRINT "DEPOSITS:      "; DE
490 PRINT "WITHDRAWALS:   "; WI
500 IF BA = 174.75 THEN PRINT "RESULT: PASS (Math exact)"
510 IF BA <> 174.75 THEN PRINT "RESULT: FAIL (Math error)"
520 PRINT ""

600 REM --- SECTION 3: MORTGAGE AMORTIZATION (GOSUB) ---
610 PRINT "--- TEST 3: MORTGAGE CALC (MATH/GOSUB) ---"
620 LO = 100000 : REM LOAN AMOUNT
630 MR = 0.04 / 12 : REM MONTHLY RATE
640 MO = 360 : REM MONTHS (30 YR)
650 REM PAYMENT FORMULA: P = L[c(1+c)^n]/[(1+c)^n - 1]
660 TE = (1 + MR) ^ MO
670 PA = LO * (MR * TE) / (TE - 1)
680 REM ROUND PAYMENT
690 PA = INT(PA * 100) / 100
700 PRINT "LOAN AMOUNT:   "; LO
710 PRINT "MONTHLY PAYMENT:"; PA
720 PRINT "FIRST 3 MONTHS BREAKDOWN:"
730 PRINT "MO", "INTEREST", "PRINCIPAL", "BALANCE"
740 FOR M = 1 TO 3
750   GOSUB 2000 : REM CALCULATE ROW
760 NEXT M
770 PRINT ""
780 GOTO 900

800 REM --- SECTION 4: STRING & FUNCTION TEST ---
900 PRINT "--- TEST 4: STRINGS & TRIG ---"
910 A$ = "HELLO"
920 B$ = " WORLD"
930 C$ = A$ + B$
940 PRINT "CONCATENATION: "; C$
950 IF C$ = "HELLO WORLD" THEN PRINT "RESULT: PASS"
960 IF C$ <> "HELLO WORLD" THEN PRINT "RESULT: FAIL"
970 REM SINE TEST
980 PI = 3.14159
990 SV = SIN(PI / 2)
1000 PRINT "SIN(PI/2): "; SV
1010 IF SV > 0.99 THEN PRINT "RESULT: PASS"
1020 IF SV <= 0.99 THEN PRINT "RESULT: FAIL"
1030 PRINT ""
1040 PRINT "ALL TESTS COMPLETED."
1050 END

2000 REM --- SUBROUTINE: CALC AMORTIZATION ROW ---
2010 IN = LO * MR
2020 IN = INT(IN * 100) / 100
2030 PR = PA - IN
2040 LO = LO - PR
2050 REM PRINT FORMATTING WITH TAB (SIMULATED)
2060 PRINT M, IN, PR, LO
2070 RETURN